# Public site
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Modeling service (Fly.io URL in prod, localhost in dev)
MODELING_SERVICE_URL=http://localhost:8000

# Clerk auth
# Get keys from https://dashboard.clerk.com → your application → API keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Webhook signing secret — required for M3b webhook handler
CLERK_WEBHOOK_SIGNING_SECRET=
# Where Clerk's hosted components render + redirect
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app/properties
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/app/properties

# Database (Neon) — wired in Milestone 2
DATABASE_URL=
# Unpooled URL for migrations/long-running queries
DATABASE_URL_UNPOOLED=

# Observability — wired in Milestone 5
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

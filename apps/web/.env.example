# Public site
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Modeling service (Fly.io URL in prod, localhost in dev)
MODELING_SERVICE_URL=http://localhost:8000

# Clerk auth
# Get keys from https://dashboard.clerk.com → your application → API keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Webhook signing secret — required for M3b webhook handler
CLERK_WEBHOOK_SIGNING_SECRET=
# Where Clerk's hosted components render + redirect
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app/properties
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/app/properties

# Database (Neon) — wired in Milestone 2
# NOTE: wrap the URL in double quotes. The query-string `&` between
# params breaks `source .env.local` in bash otherwise (parse error
# near `&`). dotenv-based loaders strip the quotes automatically.
DATABASE_URL=""
# Unpooled URL for migrations/long-running queries
DATABASE_URL_UNPOOLED=""

# Google Places Autocomplete — wired in M5 (Sprint 2)
# Get key from https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Places API (New), Maps JavaScript API
# Restrict: HTTP referrers (dwellverdict.com/*, *.vercel.app/*, localhost:3000/*)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Anthropic — wired in M7 (Sprint 2). Server-side only.
# Get key from https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Observability — wired in Milestone 5
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Google Analytics 4 — wired in M2.4. Public traffic only (root
# layout). When unset (e.g. local dev), the gtag.js script is not
# injected, so dev visits don't pollute the GA4 property. Get the
# Measurement ID from analytics.google.com → Admin → Data Streams
# → Web → your stream. Format: G-XXXXXXXXXX.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
